---
import { getCategoryList } from "../../utils/content-utils";

const categories = await getCategoryList();

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<section class:list={["taxonomy-panel taxonomy-panel--categories card-base", className]} style={style} aria-labelledby="taxonomy-categories-title">
	<header class="taxonomy-panel__header">
		<div>
			<span>Index</span>
			<h2 id="taxonomy-categories-title">Categories</h2>
		</div>
		<strong>{String(categories.length).padStart(2, "0")}</strong>
	</header>

	<nav class="taxonomy-list" aria-label="Categories">
		{categories.map((category, index) => (
			<a href={category.url} class="taxonomy-row" aria-label={`View ${category.name.trim()} posts`}>
				<span>{String(index + 1).padStart(2, "0")}</span>
				<strong>{category.name.trim()}</strong>
				<em>{String(category.count).padStart(2, "0")}</em>
			</a>
		))}
	</nav>
</section>

<style>
	.taxonomy-panel {
		position: relative;
		overflow: hidden;
		padding: 1rem;
		border: 1px solid rgb(15 23 42 / 0.08);
		background:
			linear-gradient(135deg, color-mix(in oklch, var(--primary) 9%, transparent), transparent 38%),
			var(--card-bg);
	}
	:root.dark .taxonomy-panel {
		border-color: rgb(255 255 255 / 0.08);
		background:
			linear-gradient(135deg, color-mix(in oklch, var(--primary) 13%, transparent), transparent 42%),
			var(--card-bg);
	}
	.taxonomy-panel::before {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: repeating-linear-gradient(90deg, rgb(255 255 255 / 0.035) 0 1px, transparent 1px 2.15rem);
		opacity: 0.75;
	}
	.taxonomy-panel__header,
	.taxonomy-row {
		position: relative;
		z-index: 1;
	}
	.taxonomy-panel__header {
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.8rem;
	}
	.taxonomy-panel__header span,
	.taxonomy-panel__header strong,
	.taxonomy-row span,
	.taxonomy-row em {
		font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
	}
	.taxonomy-panel__header span {
		display: block;
		color: rgb(15 23 42 / 0.42);
		font-size: 0.62rem;
		font-weight: 850;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}
	:root.dark .taxonomy-panel__header span { color: rgb(255 255 255 / 0.42); }
	.taxonomy-panel__header h2 {
		margin-top: 0.18rem;
		color: rgb(15 23 42 / 0.9);
		font-size: 1.08rem;
		font-weight: 880;
		letter-spacing: -0.03em;
	}
	:root.dark .taxonomy-panel__header h2 { color: rgb(255 255 255 / 0.9); }
	.taxonomy-panel__header strong {
		display: grid;
		min-width: 2.15rem;
		height: 2.15rem;
		place-items: center;
		border-radius: 0.72rem;
		background: color-mix(in oklch, var(--primary) 16%, transparent);
		color: var(--primary);
		font-size: 0.8rem;
	}
	.taxonomy-list {
		display: grid;
		gap: 0.28rem;
	}
	.taxonomy-row {
		display: grid;
		grid-template-columns: 2.1rem minmax(0, 1fr) auto;
		align-items: center;
		gap: 0.58rem;
		border-radius: 0.82rem;
		padding: 0.62rem 0.64rem;
		color: rgb(15 23 42 / 0.7);
	}
	:root.dark .taxonomy-row { color: rgb(255 255 255 / 0.68); }
	.taxonomy-row:hover {
		background: color-mix(in oklch, var(--primary) 12%, transparent);
		color: rgb(15 23 42 / 0.92);
	}
	:root.dark .taxonomy-row:hover { color: rgb(255 255 255 / 0.92); }
	.taxonomy-row span,
	.taxonomy-row em {
		color: rgb(15 23 42 / 0.36);
		font-size: 0.64rem;
		font-style: normal;
		font-weight: 850;
	}
	:root.dark .taxonomy-row span,
	:root.dark .taxonomy-row em { color: rgb(255 255 255 / 0.36); }
	.taxonomy-row strong {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		font-size: 0.9rem;
		font-weight: 760;
	}
	.taxonomy-row em {
		display: grid;
		min-width: 1.8rem;
		height: 1.55rem;
		place-items: center;
		border-radius: 0.58rem;
		background: rgb(15 23 42 / 0.055);
	}
	:root.dark .taxonomy-row em { background: rgb(255 255 255 / 0.055); }
</style>
