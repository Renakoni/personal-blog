---
import { siteConfig } from "../config";
import ImageWrapper from "./misc/ImageWrapper.astro";

const heroImage =
	siteConfig.banner.src || "assets/images/demo-banner.png";
const heroPosition = siteConfig.banner.position || "center";
---

<section class="home-hero relative min-h-[100svh] overflow-hidden">
	<div class="absolute inset-0">
		<ImageWrapper
			src={heroImage}
			position={heroPosition}
			alt={`Hero image for ${siteConfig.title}`}
			class="h-full w-full"
		/>
	</div>
	<div class="home-hero__veil absolute inset-0"></div>
	<div class="home-hero__noise absolute inset-0"></div>

	<div class="relative z-10 mx-auto flex min-h-[100svh] w-full max-w-[var(--page-width)] flex-col justify-end px-6 pb-24 pt-28 md:px-10 md:pb-28 lg:px-14">
		<div class="home-hero__content max-w-5xl">
			<h1 class="home-hero__wordmark onload-animation" style="animation-delay: 180ms;">
				<img
					src="/pan-wordmark.svg"
					alt="Pan"
					class="home-hero__wordmark-svg"
				/>
			</h1>
			<p class="home-hero__jp-subtitle onload-animation" style="animation-delay: 260ms;">
				夢のように愛して、愛のように夢を見て。
			</p>
		</div>
	</div>

	<div class="pointer-events-none absolute bottom-6 left-1/2 z-20 hidden -translate-x-1/2 text-white/70 md:block onload-animation" style="animation-delay: 360ms;">
		<div class="home-hero__scroll-cue flex flex-col items-center gap-2 text-xs uppercase tracking-[0.28em]">
			<span>Scroll</span>
			<span class="h-10 w-px bg-white/40"></span>
		</div>
	</div>
</section>
