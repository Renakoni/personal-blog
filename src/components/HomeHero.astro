---
import { siteConfig } from "../config";
import { getInitialHeroImages } from "../utils/initial-hero";
import ResponsivePicture from "./ResponsivePicture.astro";

const fallbackHeroImage =
	siteConfig.banner.src || "assets/images/demo-banner.png";
const fallbackHeroPosition = siteConfig.banner.position || "center";
const heroImages = getInitialHeroImages();
const initialHeroImage = heroImages[0];
const initialHeroSrc = initialHeroImage?.src || fallbackHeroImage;
const initialHeroPosition = initialHeroImage?.position || fallbackHeroPosition;
---

<section class="home-hero relative min-h-[100svh] overflow-hidden" data-hero-images={JSON.stringify(heroImages)}>
	<div class="absolute inset-0">
		{initialHeroImage?.name ? (
			<div id="home-hero-image" class="h-full w-full overflow-hidden relative">
				<ResponsivePicture
					name={initialHeroImage.name}
					alt={`Hero image for ${siteConfig.title}`}
					class="h-full w-full object-cover"
					position={initialHeroPosition}
					sizes="100vw"
					loading="eager"
				/>
			</div>
		) : (
			<img
				id="home-hero-image"
				src={initialHeroSrc}
				alt={`Hero image for ${siteConfig.title}`}
				class="h-full w-full object-cover"
				style={`object-position: ${initialHeroPosition};`}
			/>
		)}
	</div>
	<div class="home-hero__veil absolute inset-0"></div>
	<div class="home-hero__noise absolute inset-0"></div>

	<div class="home-hero__system-label onload-animation" style="animation-delay: 120ms;">PAN ARCHIVE / ONLINE</div>

	<div class="relative z-10 mx-auto flex min-h-[100svh] w-full max-w-[var(--page-width)] flex-col justify-end px-6 pb-24 pt-28 md:px-10 md:pb-28 lg:px-14">
		<div class="home-hero__content max-w-5xl">
			<h1 class="home-hero__wordmark onload-animation" style="animation-delay: 180ms;">
