---
import { Icon } from "astro-icon/components";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import type { AnimeFilterKey, AnimeItem, LoadState } from "../utils/anime";
import { ANIME_PAGE_SIZE, animeFilters, getAnimePageUrl } from "../utils/anime";

interface Props {
	items: AnimeItem[];
	state: LoadState;
	activeFilter: AnimeFilterKey;
	currentPage: number;
	totalPages: number;
	totalItems: number;
	pageTitle?: string;
}

const {
	items,
	state,
	activeFilter,
	currentPage,
	totalPages,
	totalItems,
	pageTitle = "Anime",
} = Astro.props;

const pageLinks = Array.from({ length: totalPages }, (_, index) => index + 1).filter((pageNumber) => {
	if (totalPages <= 7) return true;
	return pageNumber === 1 || pageNumber === totalPages || Math.abs(pageNumber - currentPage) <= 2;
});
const paginationItems = pageLinks.flatMap((pageNumber, index) => {
	const previous = pageLinks[index - 1];
	return previous && pageNumber - previous > 1 ? [`gap-${previous}-${pageNumber}`, pageNumber] : [pageNumber];
});
const prevUrl = currentPage > 1 ? getAnimePageUrl(activeFilter, currentPage - 1) : null;
const nextUrl = currentPage < totalPages ? getAnimePageUrl(activeFilter, currentPage + 1) : null;
const activeFilterLabel = animeFilters.find((filter) => filter.key === activeFilter)?.label || "全部";
const visibleRangeStart = totalItems === 0 ? 0 : (currentPage - 1) * ANIME_PAGE_SIZE + 1;
const visibleRangeEnd = totalItems === 0 ? 0 : Math.min((currentPage - 1) * ANIME_PAGE_SIZE + items.length, totalItems);

const statusTone: Record<number, string> = {
	1: "anime-entry--wish",
	2: "anime-entry--done",
	3: "anime-entry--watching",
};
---

<Layout title={pageTitle} description="Bangumi 动画记录">
	<div class="min-h-screen">
		<main>
			<section class="anime-archive mx-auto w-full max-w-[var(--page-width)] px-4 pb-16 pt-24 md:px-6 md:pt-28">
				<div class="mx-auto max-w-[68rem] space-y-6">
					<header class="anime-hero card-base border border-black/8 px-6 py-7 dark:border-white/8 md:px-8 md:py-8">
						<div class="anime-hero__label">
							<Icon name="material-symbols:movie-outline" class="text-[1.15rem] text-[var(--primary)]" />
							Anime Archive
						</div>

						<div class="anime-hero__grid mt-6">
							<div class="anime-hero__copy">
								<h1 class="anime-hero__title">番剧记录</h1>
								<div class="anime-hero__subtitle">WATCH / SHELF / MEMORY</div>
							</div>

							<div class="anime-control-panel" aria-label="Anime archive control panel">
								<div class="anime-control-panel__readout" aria-label="Anime archive summary">
									<div>
										<span>Filter</span>
										<strong>{activeFilterLabel}</strong>
									</div>
									<div>
										<span>Entries</span>
										<strong>{totalItems}</strong>
									</div>
									<div>
										<span>Page</span>
										<strong>{currentPage}/{totalPages}</strong>
									</div>
								</div>

								<nav class="anime-filter" aria-label="Anime filters">
									{animeFilters.map((filter) => (
										<a
											href={getAnimePageUrl(filter.key, 1)}
											class:list={["anime-filter__item", { "anime-filter__item--active": filter.key === activeFilter }]}
											aria-current={filter.key === activeFilter ? "page" : undefined}
										>
											<span>{filter.label}</span>
											<small>{filter.key}</small>
										</a>
									))}
								</nav>
							</div>
						</div>

						{state.source === "fallback" && (
							<div class="anime-hero__notice mt-5">
								<Icon name="material-symbols:info-outline-rounded" class="text-[1.1rem]" />
								{state.message}
							</div>
						)}
					</header>

					<div class="anime-archive__range">
						<span>{String(visibleRangeStart).padStart(2, "0")} — {String(visibleRangeEnd).padStart(2, "0")}</span>
						<span>{totalItems} records indexed</span>
					</div>

					<div class="anime-shelf">
						{items.map((anime, index) => (
							<article class:list={["anime-entry surface-hover card-base border border-black/8 dark:border-white/8", statusTone[anime.type] || ""]}>
								<div class="anime-entry__index">{String((currentPage - 1) * ANIME_PAGE_SIZE + index + 1).padStart(2, "0")}</div>

								<div class="anime-entry__cover-wrap">
									{anime.cover ? (
										<img
											src={anime.cover}
											alt={`${anime.title} cover`}
											loading="lazy"
											referrerpolicy="no-referrer"
											class="anime-entry__cover"
										/>
									) : (
										<div class="anime-entry__cover anime-entry__cover--empty">
											<Icon name="material-symbols:movie-outline" class="text-[2rem]" />
										</div>
									)}
								</div>

								<div class="anime-entry__content">
									<div class="anime-entry__topline">
										<span>{anime.status}</span>
										<span>{anime.episodes}</span>
										<span>{anime.date}</span>
									</div>
									<h2 class="anime-entry__title">{anime.title}</h2>
									{anime.originalTitle && anime.originalTitle !== anime.title && (
										<div class="anime-entry__original">{anime.originalTitle}</div>
									)}

									<div class="anime-entry__details">
										<div>{anime.detailsPrimary}</div>
										{anime.detailsSecondary && <div>{anime.detailsSecondary}</div>}
									</div>
								</div>
							</article>
						))}
					</div>

					{totalPages > 1 && (
						<nav class="anime-pagination" aria-label="Anime pagination">
							<a
								href={prevUrl || undefined}
								class:list={["anime-pagination__arrow", { disabled: !prevUrl }]}
								aria-disabled={prevUrl ? "false" : "true"}
							>
								<Icon name="material-symbols:chevron-left-rounded" class="text-[1.75rem]" />
							</a>
							<div class="anime-pagination__pages">
								{paginationItems.map((item) => (
									typeof item === "string" ? (
										<span class="anime-pagination__gap" aria-hidden="true">…</span>
									) : (
										<a
											href={getAnimePageUrl(activeFilter, item)}
											class:list={["anime-pagination__page", { "anime-pagination__page--active": item === currentPage }]}
											aria-current={item === currentPage ? "page" : undefined}
										>
											{item}
										</a>
									)
								))}
							</div>
							<a
								href={nextUrl || undefined}
								class:list={["anime-pagination__arrow", { disabled: !nextUrl }]}
								aria-disabled={nextUrl ? "false" : "true"}
							>
								<Icon name="material-symbols:chevron-right-rounded" class="text-[1.75rem]" />
							</a>
						</nav>
					)}

					<div class="mt-6">
						<Footer />
					</div>
				</div>
			</section>
		</main>
	</div>
</Layout>
