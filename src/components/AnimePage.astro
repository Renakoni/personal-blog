---
import { Icon } from "astro-icon/components";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";
import type { AnimeFilterKey, AnimeItem, LoadState } from "../utils/anime";
import { animeFilters, getAnimePageUrl } from "../utils/anime";

interface Props {
	items: AnimeItem[];
	state: LoadState;
	activeFilter: AnimeFilterKey;
	currentPage: number;
	totalPages: number;
	totalItems: number;
	pageTitle?: string;
}

const {
	items,
	state,
	activeFilter,
	currentPage,
	totalPages,
	totalItems,
	pageTitle = "Anime",
} = Astro.props;

const activeFilterMeta =
	animeFilters.find((item) => item.key === activeFilter) || animeFilters[0];
const pageLinks = Array.from({ length: totalPages }, (_, index) => index + 1);
const prevUrl = currentPage > 1 ? getAnimePageUrl(activeFilter, currentPage - 1) : null;
const nextUrl = currentPage < totalPages ? getAnimePageUrl(activeFilter, currentPage + 1) : null;
---

<Layout title={pageTitle} description="Bangumi 动画记录">
	<div class="min-h-screen">
		<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto">
			<div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
				<Navbar />
			</div>
		</div>

		<main id="swup-container" class="transition-swup-fade">
			<section class="mx-auto w-full max-w-[var(--page-width)] px-4 pb-16 pt-24 md:px-6 md:pt-28">
				<div class="mx-auto max-w-[56rem]">
					<div class="card-base onload-animation border border-[var(--line-color)] px-6 py-7 md:px-8 md:py-8">
						<div class="flex flex-wrap items-start justify-between gap-4">
							<div>
								<div class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.24em] text-50">
									<Icon name="material-symbols:movie-outline" class="text-xl text-[var(--primary)]" />
									Anime
								</div>
								<h1 class="mt-3 text-4xl font-semibold leading-tight text-90 md:text-5xl">番剧</h1>
								<p class="mt-4 max-w-2xl text-sm leading-7 text-75 md:text-base md:leading-8">
									单栏展示的动画记录页。当前分类为“{activeFilterMeta.label}”，本页显示 {items.length} / {totalItems} 条记录。
								</p>
							</div>
							<div class:list={["rounded-full px-4 py-2 text-sm font-semibold", state.source === "bangumi"
								? "bg-[var(--btn-regular-bg)] text-[var(--primary)]"
								: "bg-[var(--btn-regular-bg)] text-[var(--btn-content)]"]}>
								{state.message}
							</div>
						</div>

						<nav class="mt-6 flex flex-wrap gap-3 border-t border-[var(--line-color)] pt-5" aria-label="Anime filters">
							{animeFilters.map((filter) => (
								<a
									href={getAnimePageUrl(filter.key, 1)}
									class:list={[
										"inline-flex min-h-10 items-center justify-center rounded-full border px-4 py-2 text-sm font-semibold transition",
										filter.key === activeFilter
											? "border-[color:var(--primary)] bg-[var(--btn-regular-bg)] text-[var(--primary)]"
											: "border-[var(--line-color)] bg-[var(--card-bg)] text-75 hover:text-[var(--primary)] hover:border-[color:var(--primary)]",
									]}
									aria-current={filter.key === activeFilter ? "page" : undefined}
								>
									{filter.label}
								</a>
							))}
						</nav>
					</div>

					<div class="mt-6 flex flex-col gap-4">
						{items.map((anime, index) => (
							<article
								class="card-base onload-animation overflow-hidden border border-[var(--line-color)] px-4 py-4 md:px-5"
								style={`animation-delay: calc(var(--content-delay) + ${index * 40}ms);`}
							>
								<div class="flex items-start gap-4 md:gap-5">
									<div class="h-32 w-24 shrink-0 overflow-hidden rounded-2xl bg-[var(--btn-regular-bg)] md:h-40 md:w-28">
										{anime.cover ? (
											<img
												src={anime.cover}
												alt={`${anime.title} cover`}
												loading="lazy"
												referrerpolicy="no-referrer"
												class="h-full w-full object-cover"
											/>
										) : (
											<div class="flex h-full w-full items-center justify-center text-[var(--btn-content)]">
												<Icon name="material-symbols:movie-outline" class="text-4xl" />
											</div>
										)}
									</div>

									<div class="min-w-0 flex-1">
										<div class="flex flex-wrap items-center justify-between gap-3">
											<div class="flex flex-wrap items-center gap-2">
												<span class="inline-flex min-h-8 items-center rounded-full bg-[var(--btn-regular-bg)] px-3 text-xs font-semibold text-[var(--primary)]">
													{anime.status}
												</span>
												<span class="inline-flex min-h-8 items-center rounded-full bg-[var(--btn-regular-bg)] px-3 text-xs font-semibold text-[var(--btn-content)]">
													{anime.episodes}
												</span>
											</div>
											<div class="text-sm font-medium text-50">{anime.date}</div>
										</div>

										<h2 class="mt-4 text-2xl font-semibold leading-tight text-90">{anime.title}</h2>
										{anime.originalTitle && anime.originalTitle !== anime.title && (
											<div class="mt-2 text-sm font-medium leading-6 text-50">{anime.originalTitle}</div>
										)}
										<div class="mt-4 text-sm leading-7 text-75">{anime.staff}</div>
									</div>
								</div>
							</article>
						))}
					</div>

					{totalPages > 1 && (
						<nav class="mt-6 flex items-center justify-center gap-3 onload-animation" aria-label="Anime pagination">
							<a
								href={prevUrl || undefined}
								class:list={["btn-card h-11 w-11 rounded-lg overflow-hidden", { disabled: !prevUrl }]}
								aria-disabled={prevUrl ? "false" : "true"}
							>
								<Icon name="material-symbols:chevron-left-rounded" class="text-[1.75rem]" />
							</a>
							<div class="flex flex-wrap items-center gap-2 rounded-xl bg-[var(--card-bg)] p-2">
								{pageLinks.map((pageNumber) => (
									<a
										href={getAnimePageUrl(activeFilter, pageNumber)}
										class:list={[
											"flex h-10 min-w-10 items-center justify-center rounded-lg px-3 text-sm font-semibold transition",
											pageNumber === currentPage
												? "bg-[var(--primary)] text-white dark:text-[var(--deep-text)]"
												: "text-75 hover:bg-[var(--btn-card-bg-hover)] hover:text-[var(--primary)]",
										]}
										aria-current={pageNumber === currentPage ? "page" : undefined}
									>
										{pageNumber}
									</a>
								))}
							</div>
							<a
								href={nextUrl || undefined}
								class:list={["btn-card h-11 w-11 rounded-lg overflow-hidden", { disabled: !nextUrl }]}
								aria-disabled={nextUrl ? "false" : "true"}
							>
								<Icon name="material-symbols:chevron-right-rounded" class="text-[1.75rem]" />
							</a>
						</nav>
					)}

					<div class="mt-8">
						<Footer />
					</div>
				</div>
			</section>
		</main>
	</div>
</Layout>
