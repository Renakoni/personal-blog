---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { pathsEqual, url } from "../utils/url-utils";
import LightDarkSwitchClient from "./LightDarkSwitchClient.svelte";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import NavMenuPanel from "./widget/NavMenuPanel.astro";

const className = Astro.props.class;
const customLinks = Astro.props.links;

let links: NavBarLink[] = (customLinks || navBarConfig.links).map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return LinkPresets[item];
		}
		return item;
	},
);

const getActiveNavName = (pathname: string) => {
	if (pathname.startsWith("/anime")) return "Anime";
	if (pathname.startsWith("/projects")) return "Projects";
	if (pathname.startsWith("/notes")) return "Notes";
	if (pathname.startsWith("/about")) return "About";
	if (pathname.startsWith("/archive") || pathname.startsWith("/posts")) return "Blog";
	if (pathsEqual(pathname, "/")) return "Home";
	return "";
};

const activeNavName = getActiveNavName(Astro.url.pathname);
---
<div id="navbar" class="z-50 onload-animation">
    <div class="absolute h-8 left-0 right-0 -top-8 bg-[var(--card-bg)] transition"></div> <!-- used for onload animation -->
    <div class:list={[
        className,
        "card-base !overflow-visible max-w-[var(--page-width)] h-[4.5rem] !rounded-t-none mx-auto flex items-center justify-between px-4"]}>
        <a href={url('/')} class="btn-plain scale-animation rounded-lg h-[3.25rem] px-5 font-bold active:scale-95">
            <div class="flex flex-row text-[var(--primary)] items-center text-md">
                <Icon name="material-symbols:home-outline-rounded" class="text-[1.75rem] mb-1 mr-2" />
                Pan
            </div>
        </a>
        <div class="hidden md:flex">
            {links.map((l) => {
                const isActive = !l.external && l.name === activeNavName;
                return <a
                          aria-label={l.name}
                          aria-current={isActive ? "page" : null}
                          href={l.external ? l.url : url(l.url)}
                          target={l.external ? "_blank" : null}
                          class:list={[
                              "nav-link btn-plain scale-animation rounded-lg h-11 font-bold px-4 active:scale-95",
                              { "nav-link--active": isActive },
                          ]}
                >
                    <div class="flex items-center gap-2">
                        {l.name === "Home" && <Icon name="material-symbols:home-outline-rounded" class="nav-link__icon text-[1.1rem]"></Icon>}
                        {l.name === "Blog" && <Icon name="material-symbols:article-outline-rounded" class="nav-link__icon text-[1.1rem]"></Icon>}
                        {l.name === "Notes" && <Icon name="material-symbols:edit-note-rounded" class="nav-link__icon text-[1.1rem]"></Icon>}
                        {l.name === "Anime" && <Icon name="material-symbols:movie-outline" class="nav-link__icon nav-link__icon--anime text-[1.1rem]"></Icon>}
                        {l.name === "Projects" && <Icon name="material-symbols:code-rounded" class="nav-link__icon text-[1.1rem]"></Icon>}
                        {l.name === "About" && <Icon name="material-symbols:person-outline-rounded" class="nav-link__icon text-[1.1rem]"></Icon>}
                        {l.name === "GitHub" && <Icon name="fa6-brands:github" class="nav-link__icon text-[1.1rem]"></Icon>}
                        <span>{l.name}</span>
                        {l.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.875rem] transition -translate-y-[1px] ml-0.5 opacity-35"></Icon>}
                    </div>
                </a>;
            })}
        </div>
        <div class="flex">
            <!--<SearchPanel client:load>-->
            <Search client:load></Search>
            {!siteConfig.themeColor.fixed && (
                    <button aria-label="Display Settings" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="display-settings-switch">
                        <Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                    </button>
            )}
            <LightDarkSwitchClient client:load></LightDarkSwitchClient>
            <button aria-label="Menu" name="Nav Menu" class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 md:!hidden" id="nav-menu-switch">
                <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
            </button>
        </div>
        <NavMenuPanel links={links} activeNavName={activeNavName}></NavMenuPanel>
        <DisplaySettings client:load></DisplaySettings>
    </div>
</div>

<script>
function loadButtonScript() {
    let settingBtn = document.getElementById("display-settings-switch");
    if (settingBtn) {
        settingBtn.onclick = function () {
            let settingPanel = document.getElementById("display-setting");
            if (settingPanel) {
                settingPanel.classList.toggle("float-panel-closed");
            }
        };
    }

    let menuBtn = document.getElementById("nav-menu-switch");
    if (menuBtn) {
        menuBtn.onclick = function () {
            let menuPanel = document.getElementById("nav-menu-panel");
            if (menuPanel) {
                menuPanel.classList.toggle("float-panel-closed");
            }
        };
    }
}

function getActiveNavName(pathname: string) {
    if (pathname.startsWith("/anime")) return "Anime";
    if (pathname.startsWith("/projects")) return "Projects";
    if (pathname.startsWith("/notes")) return "Notes";
    if (pathname.startsWith("/about")) return "About";
    if (pathname.startsWith("/archive") || pathname.startsWith("/posts")) return "Blog";
    if (pathname === "/") return "Home";
    return "";
}

function syncActiveNav() {
    const activeName = getActiveNavName(window.location.pathname);
    document.querySelectorAll("#navbar a[aria-label]").forEach((link) => {
        const isActive = link.getAttribute("aria-label") === activeName && !link.hasAttribute("target");
        link.toggleAttribute("aria-current", isActive);
        if (isActive) link.setAttribute("aria-current", "page");
        link.classList.toggle("nav-link--active", isActive && link.classList.contains("nav-link"));
        link.classList.toggle("nav-menu-link--active", isActive && !link.classList.contains("nav-link"));
    });
}

loadButtonScript();
syncActiveNav();
document.addEventListener("astro:page-load", syncActiveNav);
if (window.swup?.hooks) {
    window.swup.hooks.on("page:view", syncActiveNav);
} else {
    document.addEventListener("swup:enable", () => window.swup?.hooks?.on("page:view", syncActiveNav));
}
</script>

{import.meta.env.PROD && <script is:inline define:vars={{scriptUrl: url('/pagefind/pagefind.js')}}>
async function loadPagefind() {
    try {
        const response = await fetch(scriptUrl, { method: 'HEAD' });
        if (!response.ok) {
            throw new Error(`Pagefind script not found: ${response.status}`);
        }

        const pagefind = await import(scriptUrl);

        await pagefind.options({
            excerptLength: 20
        });

        window.pagefind = pagefind;

        document.dispatchEvent(new CustomEvent('pagefindready'));
        console.log('Pagefind loaded and initialized successfully, event dispatched.');
    } catch (error) {
        console.error('Failed to load Pagefind:', error);
        window.pagefind = {
            search: () => Promise.resolve({ results: [] }),
            options: () => Promise.resolve(),
        };
        document.dispatchEvent(new CustomEvent('pagefindloaderror'));
        console.log('Pagefind load error, event dispatched.');
    }
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadPagefind);
} else {
    loadPagefind();
}
</script>}

