---
import { Icon } from "astro-icon/components";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const projects = [
	{
		name: "Personal Blog",
		type: "Website",
		status: "Building",
		description: "A personal site based on Fuwari, redesigned with a stronger visual homepage and custom content pages.",
		link: "/",
		icon: "material-symbols:article-outline",
	},
	{
		name: "Anime Shelf",
		type: "Collection",
		status: "Draft",
		description: "A curated watchlist page for anime notes, scores, and personal impressions.",
		link: "/anime/",
		icon: "material-symbols:movie-outline",
	},
	{
		name: "Future Project",
		type: "Placeholder",
		status: "Planned",
		description: "Reserve this slot for a tool, research note, demo, or repository that deserves a short introduction.",
		link: "https://github.com/saicaca/fuwari",
		icon: "fa6-brands:github",
		external: true,
	},
];
---

<MainGridLayout title="Projects" description="Projects, experiments, and selected work">
	<section class="space-y-6">
		<div class="card-base px-7 py-8 md:px-10 md:py-10">
			<div class="mb-3 flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.24em] text-50">
				<Icon name="material-symbols:code-rounded" class="text-xl text-[var(--primary)]" />
				Selected Work
			</div>
			<h1 class="text-4xl font-semibold leading-tight text-90 md:text-5xl">Projects</h1>
			<p class="mt-4 max-w-2xl text-base leading-8 text-75">
				A place for things worth keeping visible: tools, experiments, notes, and finished work.
			</p>
		</div>

		<div class="grid gap-4 md:grid-cols-2">
			{projects.map((project) => (
				<a
					href={project.link}
					target={project.external ? "_blank" : null}
					class="card-base group block px-6 py-6 active:scale-[0.99]"
				>
					<div class="mb-5 flex items-start justify-between gap-4">
						<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--btn-regular-bg)] text-[var(--primary)]">
							<Icon name={project.icon} class="text-2xl" />
						</div>
						<span class="rounded-full bg-[var(--btn-regular-bg)] px-3 py-1 text-xs font-semibold text-[var(--btn-content)]">{project.status}</span>
					</div>
					<div class="text-sm font-semibold uppercase tracking-[0.18em] text-50">{project.type}</div>
					<h2 class="mt-2 text-2xl font-semibold text-90 group-hover:text-[var(--primary)]">{project.name}</h2>
					<p class="mt-3 text-sm leading-7 text-75">{project.description}</p>
				</a>
			))}
		</div>
	</section>
</MainGridLayout>
