---
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { url } from "../utils/url-utils";

const stackColumns = [
	{
		label: "Languages",
		accent: "var(--about-accent-1)",
		items: ["Python", "TypeScript", "Dart", "Java"],
	},
	{
		label: "Frontend",
		accent: "var(--about-accent-2)",
		items: ["Astro", "Tailwind CSS", "Vue", "CSS"],
	},
	{
		label: "Toolkit",
		accent: "var(--about-accent-3)",
		items: ["PyTorch", "Git", "Prompting"],
	},
];

const stackMarquee = [
	"Python",
	"TypeScript",
	"Astro",
	"Tailwind CSS",
	"Dart",
	"Vue",
	"PyTorch",
	"Java",
	"CSS",
	"Git",
	"Prompting",
	"Astro",
];
---
<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)} showSidebar={false}>
	<div class="about-page about-page--stage">
		<div class="about-deck" aria-label="About Pan presentation">
			<section class="about-slide about-slide--cover" aria-labelledby="about-cover-title">
				<div class="about-cover-paper" aria-hidden="true">
					<div class="about-cover-registration about-cover-registration--tl"></div>
					<div class="about-cover-registration about-cover-registration--tr"></div>
					<div class="about-cover-registration about-cover-registration--bl"></div>
					<div class="about-cover-registration about-cover-registration--br"></div>
					<div class="about-cover-tape about-cover-tape--top"></div>
					<div class="about-cover-tape about-cover-tape--side"></div>
					<svg class="about-cover-pencil-lines" viewBox="0 0 1200 760" preserveAspectRatio="none" focusable="false">
						<path d="M92 132 C 248 106, 424 112, 582 150 S 910 192, 1094 136" />
						<path d="M160 612 C 286 552, 412 534, 560 572 S 846 668, 1028 594" />
						<path d="M182 228 L 1048 228" />
						<path d="M182 468 L 1048 468" />
						<path d="M286 88 L 286 684" />
						<path d="M904 86 L 904 684" />
						<circle cx="916" cy="248" r="88" />
						<path d="M864 332 C 938 312, 1016 330, 1064 384" />
					</svg>
					<svg class="about-cover-pan-mark about-reveal" viewBox="0 0 920 360" role="img" aria-labelledby="about-cover-title" style="--motion-reveal-index: 1;">
						<title>PAN</title>
						<g class="about-cover-pan-mark__draft">
							<path d="M76 302 L 76 58 C 124 45, 232 43, 266 102 C 306 172, 232 236, 78 220" />
							<path d="M334 306 L 442 52 L 552 306 M386 202 C 432 190, 484 190, 528 204" />
							<path d="M642 306 L 642 58 L 814 304 L 814 52" />
						</g>
						<g class="about-cover-pan-mark__ink">
							<path d="M72 300 L 72 62 C 122 50, 226 46, 262 104 C 302 168, 230 228, 74 216" />
							<path d="M330 304 L 438 56 L 548 304 M384 198 C 430 188, 482 188, 526 202" />
							<path d="M638 304 L 638 60 L 812 302 L 812 56" />
						</g>
						<g class="about-cover-pan-mark__blue">
							<path d="M58 326 C 228 340, 392 326, 560 334 S 750 348, 858 324" />
							<path d="M572 72 C 668 34, 772 36, 846 76" />
						</g>
					</svg>
				</div>
				<div class="about-slide__inner about-slide__inner--cover">
					<div class="about-cover-dossier-meta about-reveal" style="--motion-reveal-index: 0;">
						<span>PERSONAL FILE / 01</span>
						<span>opened at 2026</span>
					</div>
					<div class="about-cover-theatre">
						<div class="about-kicker about-reveal" style="--motion-reveal-index: 2;">Paper Signal Theatre</div>
						<h1 id="about-cover-title" class="about-cover-title about-reveal" style="--motion-reveal-index: 3;">PAN</h1>
						<p class="about-cover-subtitle about-reveal" style="--motion-reveal-index: 4;">private notes, builds, favorites</p>
					</div>
					<div class="about-cover-note about-cover-note--blue about-reveal" style="--motion-reveal-index: 5;">
						<span>signal route</span>
						<b>blog / anime / code</b>
					</div>
					<div class="about-cover-pencil-tag about-reveal" style="--motion-reveal-index: 6;" aria-hidden="true"></div>
					<div class="about-cover-red-mark about-reveal" style="--motion-reveal-index: 7;" aria-hidden="true">revise</div>
					<div class="about-slide-count about-reveal" style="--motion-reveal-index: 8;">01 / 06</div>
				</div>
			</section>

			<section class="about-slide about-slide--now" aria-labelledby="about-now-title">
				<div class="about-current-paper" aria-hidden="true">
					<div class="about-current-watermark">02</div>
					<svg class="about-current-route" viewBox="0 0 1200 720" preserveAspectRatio="none" focusable="false">
						<path class="about-current-route__pencil" d="M118 188 C 298 142, 432 192, 520 292 S 740 456, 1002 348" />
						<path class="about-current-route__blue" d="M270 224 C 426 248, 486 340, 574 390 S 724 458, 878 414" />
						<path class="about-current-route__blue about-current-route__blue--second" d="M832 420 C 704 494, 556 516, 360 548" />
					</svg>
				</div>
				<div class="about-slide__inner about-slide__inner--current">
					<div class="about-current-head about-reveal" style="--motion-reveal-index: 0;">
						<div class="about-kicker">Current Notes / 02</div>
						<h2 id="about-now-title">private build log</h2>
					</div>
					<div class="about-current-notes" aria-label="Current notes">
						<article class="about-current-note about-current-note--site about-reveal" style="--motion-reveal-index: 1;">
							<div class="about-current-note__index">01</div>
							<h3>Site Tuning</h3>
							<ul>
								<li>visual system</li>
								<li>motion rhythm</li>
								<li>paper theatre</li>
							</ul>
						</article>
						<article class="about-current-note about-current-note--archive about-reveal" style="--motion-reveal-index: 2;">
							<div class="about-current-note__index">02</div>
							<h3>Archive Building</h3>
							<ul>
								<li>posts</li>
								<li>projects</li>
								<li>watch log</li>
							</ul>
						</article>
						<article class="about-current-note about-current-note--taste about-reveal" style="--motion-reveal-index: 3;">
							<div class="about-current-note__index">03</div>
							<h3>Taste Calibration</h3>
							<ul>
								<li>anime mood</li>
								<li>technical order</li>
								<li>quiet memory</li>
							</ul>
						</article>
					</div>
					<div class="about-current-redline about-reveal" style="--motion-reveal-index: 4;" aria-hidden="true">
						<span>resume</span>
						<b>archive</b>
					</div>
					<div class="about-current-footer about-reveal" style="--motion-reveal-index: 5;">not final / still collecting signal</div>
				</div>
			</section>

			<section class="about-slide about-slide--signal" aria-labelledby="about-signal-title">
				<div class="about-build-paper" aria-hidden="true">
					<div class="about-build-watermark">BUILD</div>
					<svg class="about-build-annotation" viewBox="0 0 1200 720" preserveAspectRatio="none" focusable="false">
						<path class="about-build-annotation__pencil" d="M132 236 L 1066 236" />
						<path class="about-build-annotation__pencil" d="M132 396 L 1066 396" />
						<path class="about-build-annotation__blue" d="M514 286 C 602 258, 700 258, 798 286" />
						<path class="about-build-annotation__blue" d="M506 548 C 598 574, 704 574, 806 548" />
					</svg>
				</div>
				<div class="about-slide__inner about-slide__inner--build">
					<div class="about-build-head about-reveal" style="--motion-reveal-index: 0;">
						<div class="about-kicker">Build Inventory / 03</div>
						<h2 id="about-signal-title">materials, tools, traces</h2>
					</div>
					<div class="about-build-ledger" aria-label="Build inventory">
						<section class="about-build-lane about-build-lane--lang about-reveal" style="--motion-reveal-index: 1;">
							<div class="about-build-lane__head"><span>A / LANG</span></div>
							<ul>
								<li><b>Python</b><span>model notes</span></li>
								<li class="about-build-item--marked"><b>TypeScript</b><span>site logic</span></li>
								<li><b>Dart</b><span>app side</span></li>
								<li><b>Java</b><span>old track</span></li>
							</ul>
						</section>
						<section class="about-build-lane about-build-lane--surface about-reveal" style="--motion-reveal-index: 2;">
							<div class="about-build-lane__head"><span>B / SURFACE</span></div>
							<ul>
								<li class="about-build-item--marked"><b>Astro</b><span>site shell</span></li>
								<li><b>Tailwind CSS</b><span>material layer</span></li>
								<li><b>Vue</b><span>component lab</span></li>
								<li class="about-build-item--marked"><b>CSS</b><span>final texture</span></li>
							</ul>
						</section>
						<section class="about-build-lane about-build-lane--tools about-reveal" style="--motion-reveal-index: 3;">
							<div class="about-build-lane__head"><span>C / TOOLS</span></div>
							<ul>
								<li><b>PyTorch</b><span>model work</span></li>
								<li><b>Git</b><span>archive trace</span></li>
								<li><b>Prompting</b><span>direction tool</span></li>
							</ul>
						</section>
					</div>
					<div class="about-build-redline about-reveal" style="--motion-reveal-index: 4;" aria-hidden="true">
						<span>badges</span>
						<b>materials</b>
					</div>
					<div class="about-build-footer about-reveal" style="--motion-reveal-index: 5;">compiled by hand / revised in browser</div>
				</div>
			</section>

			<section class="about-slide about-slide--texture about-slide--favorites-a" aria-labelledby="about-texture-title">
				<div class="about-favorites-paper" aria-hidden="true">
					<div class="about-favorites-watermark">VISUAL</div>
					<div class="about-favorites-record"></div>
					<svg class="about-favorites-circle" viewBox="0 0 320 160" focusable="false">
						<path d="M42 72 C 74 18, 210 20, 264 58 C 310 90, 260 136, 158 132 C 64 128, 14 108, 42 72" />
					</svg>
				</div>
				<div class="about-slide__inner about-slide__inner--favorites">
					<div class="about-favorites-head about-reveal" style="--motion-reveal-index: 0;">
						<div class="about-kicker">Favorites Contact Sheet / 04</div>
						<h2 id="about-texture-title">anime and game frames</h2>
					</div>
					<div class="about-favorites-gallery about-favorites-gallery--paired" aria-label="Anime and game image frames">
						<article class="about-favorite-frame about-favorite-frame--large about-favorite-frame--anime about-reveal" style="--motion-reveal-index: 1;">
							<div class="about-favorite-frame__slot"><span>anime image pending</span></div>
							<div class="about-favorite-frame__caption"><span>01 / Anime</span><b>title / author pending</b></div>
						</article>
						<div class="about-favorite-note about-favorite-note--anime about-reveal" style="--motion-reveal-index: 2;">
							<span>01 / Anime note</span>
							<p>Caption text pending. This is where the longer personal sentence goes, not below the image.</p>
						</div>
						<article class="about-favorite-frame about-favorite-frame--large about-favorite-frame--game about-reveal" style="--motion-reveal-index: 3;">
							<div class="about-favorite-frame__slot"><span>game image pending</span></div>
							<div class="about-favorite-frame__caption"><span>02 / Game</span><b>title / studio pending</b></div>
						</article>
						<div class="about-favorite-note about-favorite-note--game about-reveal" style="--motion-reveal-index: 4;">
							<span>02 / Game note</span>
							<p>Caption text pending. A second short paragraph can explain why this work belongs here.</p>
						</div>
					</div>
					<div class="about-favorites-side about-reveal" style="--motion-reveal-index: 3;" aria-hidden="true">
						<span>Part A</span>
						<b>Visual Favorites</b>
						<small>02 frames</small>
					</div>
					<div class="about-favorites-redline about-reveal" style="--motion-reveal-index: 4;" aria-hidden="true">not ranking</div>
					<div class="about-favorites-footer about-reveal" style="--motion-reveal-index: 5;">images can replace these paper frames later</div>
				</div>
			</section>

			<section class="about-slide about-slide--texture about-slide--favorites-b" aria-labelledby="about-favorites-b-title">
				<div class="about-favorites-paper" aria-hidden="true">
					<div class="about-favorites-watermark">SHELF</div>
					<div class="about-favorites-record"></div>
				</div>
				<div class="about-slide__inner about-slide__inner--favorites">
					<div class="about-favorites-head about-reveal" style="--motion-reveal-index: 0;">
						<div class="about-kicker">Favorites Contact Sheet / 05</div>
						<h2 id="about-favorites-b-title">sound and reading frames</h2>
					</div>
					<div class="about-favorites-gallery about-favorites-gallery--paired about-favorites-gallery--shelf" aria-label="Music and novel manga image frames">
						<article class="about-favorite-frame about-favorite-frame--album about-favorite-frame--sound about-reveal" style="--motion-reveal-index: 1;">
							<div class="about-favorite-frame__slot"><span>album cover pending</span></div>
							<div class="about-favorite-frame__caption"><span>03 / Music</span><b>album / artist pending</b></div>
						</article>
						<div class="about-favorite-note about-favorite-note--sound about-reveal" style="--motion-reveal-index: 2;">
							<span>03 / Music note</span>
							<p>Caption text pending. This area can hold the feeling, memory, or listening scene.</p>
						</div>
						<article class="about-favorite-frame about-favorite-frame--large about-favorite-frame--manga about-reveal" style="--motion-reveal-index: 3;">
							<div class="about-favorite-frame__slot"><span>novel / manga image pending</span></div>
							<div class="about-favorite-frame__caption"><span>04 / Novel + Manga</span><b>title / author pending</b></div>
						</article>
						<div class="about-favorite-note about-favorite-note--manga about-reveal" style="--motion-reveal-index: 4;">
							<span>04 / Reading note</span>
							<p>Caption text pending. A quiet note can explain the aftertaste or recurring image.</p>
						</div>
					</div>
					<div class="about-favorites-side about-reveal" style="--motion-reveal-index: 3;" aria-hidden="true">
						<span>Part B</span>
						<b>Shelf Favorites</b>
						<small>02 frames</small>
					</div>
					<div class="about-favorites-redline about-reveal" style="--motion-reveal-index: 4;" aria-hidden="true">not ranking</div>
					<div class="about-favorites-footer about-reveal" style="--motion-reveal-index: 5;">more room for captions, less wall-of-covers</div>
				</div>
			</section>

			<section class="about-slide about-slide--stack" aria-labelledby="about-stack-title">
				<div class="about-slide__inner">
					<div class="about-kicker about-reveal">Stack credits</div>
					<h2 id="about-stack-title" class="about-slide-title about-reveal" style="--motion-reveal-index: 1;">制作名单。</h2>
					<div class="about-stack-marquee-wrap about-reveal" style="--motion-reveal-index: 2;">
						<div class="about-stack-marquee">
							<div class="about-stack-marquee__track">
								{stackMarquee.map((item) => <span>{item}</span>)}
								{stackMarquee.map((item) => <span>{item}</span>)}
							</div>
						</div>
					</div>
					<div class="about-stack-grid">
						{stackColumns.map((column, index) => (
							<article class="about-stack-column about-reveal" style={`--about-stack-accent:${column.accent}; --motion-reveal-index: ${index + 3};`}>
								<div class="about-stack-column__head">
									<div class="about-stack-column__label">{column.label}</div>
									<span class="about-stack-column__pulse"></span>
								</div>
								<div class="about-stack-column__list mt-4">
									{column.items.map((item) => <div class="about-stack-column__item">{item}</div>)}
								</div>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="about-slide about-slide--exit" aria-labelledby="about-exit-title">
				<div class="about-slide__inner about-slide__inner--narrow">
					<div class="about-kicker about-reveal">Continue</div>
					<h2 id="about-exit-title" class="about-slide-title about-reveal" style="--motion-reveal-index: 1;">如果你想继续看，可以从这里进入。</h2>
					<div class="about-exit-actions about-reveal" style="--motion-reveal-index: 2;">
						<a href={url("/blog/")}>Blog</a>
						<a href={url("/projects/")}>Projects</a>
						<a href={url("/anime/")}>Anime</a>
					</div>
					<div class="about-slide-count about-reveal" style="--motion-reveal-index: 3;">07 / 07</div>
					<footer class="about-exit-footer about-reveal" style="--motion-reveal-index: 4;">
						© 2026 Pan. Built with <a href="https://astro.build/" target="_blank" rel="noopener">Astro</a>. / <a href={url("/rss.xml")}>RSS</a> / <a href={url("/sitemap-index.xml")}>Sitemap</a>
					</footer>
				</div>
			</section>
		</div>
	</div>
</MainGridLayout>
