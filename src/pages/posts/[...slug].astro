---
import path from "node:path";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getDir, getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";
import { licenseConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import PostMetadata from "../../components/PostMeta.astro";
import SideBar from "../../components/widget/SideBar.astro";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	return blogEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const { remarkPluginFrontmatter } = await entry.render();

const wordCount = remarkPluginFrontmatter.words;
const readingMinutes = remarkPluginFrontmatter.minutes;
const postId = `LOG-${formatDateToYYYYMMDD(entry.data.published).replaceAll("-", "")}`;
const hasCover = !!entry.data.image;
const tagSummary = entry.data.tags?.length ? entry.data.tags.join(" / ") : i18n(I18nKey.noTags);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	dateModified: entry.data.updated ? formatDateToYYYYMMDD(entry.data.updated) : undefined,
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
	image: entry.data.image || undefined,
};
---
<MainGridLayout banner={entry.data.image} title={entry.data.title} description={entry.data.description} lang={entry.data.lang} setOGTypeArticle={true} headings={headings}>
	<SideBar
		slot="sidebar"
		showTaxonomy={false}
		class="mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem] onload-animation"
	></SideBar>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

	<article id="post-container" class:list={["post-case card-base relative overflow-hidden border border-black/8 dark:border-white/8", { "post-case--with-cover": hasCover }]}>
		<header class="post-case__hero">
			<div class="post-case__label onload-animation">
				<span>{postId}</span>
				<span>{entry.data.category || i18n(I18nKey.uncategorized)}</span>
			</div>

			<div class="post-case__title-grid mt-5">
				<div>
					<h1 data-pagefind-body data-pagefind-weight="10" data-pagefind-meta="title" class="post-case__title onload-animation" style="animation-delay: 80ms;">
						{entry.data.title}
					</h1>
					{entry.data.description && (
						<p class="post-case__dek onload-animation" style="animation-delay: 140ms;">{entry.data.description}</p>
					)}
				</div>

				<aside class="post-case__readout onload-animation" aria-label="Article readout" style="animation-delay: 180ms;">
					<div>
						<span>Words</span>
						<strong>{wordCount}</strong>
					</div>
					<div>
						<span>Read</span>
						<strong>{readingMinutes} min</strong>
					</div>
				</aside>
			</div>

			<div class="post-case__meta onload-animation" style="animation-delay: 220ms;">
				<PostMetadata
					class=""
					published={entry.data.published}
					updated={entry.data.updated}
					tags={entry.data.tags}
					category={entry.data.category}
				/>
			</div>
		</header>

		{hasCover && (
			<figure class="post-case__cover onload-animation" style="animation-delay: 260ms;">
				<ImageWrapper id="post-cover" src={entry.data.image} basePath={path.join("content/posts/", getDir(entry.id))} class="post-case__cover-image banner-container" />
				<figcaption>{tagSummary}</figcaption>
			</figure>
		)}

		<div class="post-case__body-shell">
			<div class="post-case__rail" aria-hidden="true">
				<span>TEXT</span>
				<span>{formatDateToYYYYMMDD(entry.data.published)}</span>
			</div>

			<Markdown class="post-case__content markdown-content onload-animation">
				<Content />
			</Markdown>
		</div>

		{licenseConfig.enable && <License title={entry.data.title} slug={entry.slug} pubDate={entry.data.published} class="post-case__license mb-6 rounded-xl license-container onload-animation"></License>}
	</article>

	<nav class="post-case__nav" aria-label="Adjacent posts">
		<a href={entry.data.nextSlug ? getPostUrlBySlug(entry.data.nextSlug) : "#"}
		   class:list={["post-case__nav-card", { "pointer-events-none opacity-45": !entry.data.nextSlug }]}>
			<span>Previous file</span>
			{entry.data.nextSlug && <strong>{entry.data.nextTitle}</strong>}
			<Icon name="material-symbols:chevron-left-rounded" class="text-[1.6rem]" />
		</a>

		<a href={entry.data.prevSlug ? getPostUrlBySlug(entry.data.prevSlug) : "#"}
		   class:list={["post-case__nav-card post-case__nav-card--next", { "pointer-events-none opacity-45": !entry.data.prevSlug }]}>
			<span>Next file</span>
			{entry.data.prevSlug && <strong>{entry.data.prevTitle}</strong>}
			<Icon name="material-symbols:chevron-right-rounded" class="text-[1.6rem]" />
		</a>
	</nav>
</MainGridLayout>
